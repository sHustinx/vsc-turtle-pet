    "version": "0.2.0",

    "configurations": [
        // always run extension.js when pressing F5
        {
            "name": "Run Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
            "outFiles": ["${workspaceFolder}/extension.js"]
        }
    ]
}